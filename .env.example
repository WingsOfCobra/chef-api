# ─── Core ────────────────────────────────────────────────────────────────────
CHEF_API_KEY=your-secret-api-key-here
PORT=4242
HOST=0.0.0.0

# ─── Docker ──────────────────────────────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock
# Docker Compose: which interface to bind on (e.g. 127.0.0.1 or a VPN IP)
BIND_ADDR=127.0.0.1
# Docker Compose: host path to mount as /workspace inside the container (read-only)
WORKSPACE_PATH=/path/to/your/workspace

# ─── SSH ─────────────────────────────────────────────────────────────────────
# Format: name:user@host:~/.ssh/keyname (comma-separated for multiple)
SSH_HOSTS=localhost:user@host:~/.ssh/id_ed25519
# Which SSH host to use for systemd service monitoring and network commands
SERVICES_SSH_HOST=localhost

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here

# ─── Todo ────────────────────────────────────────────────────────────────────
TODO_PATH=/path/to/your/TODO.md

# ─── Cron ────────────────────────────────────────────────────────────────────
# Timezone for scheduled jobs (default: UTC)
CRON_TIMEZONE=UTC

# ─── Email (IMAP) ───────────────────────────────────────────────────────────
# Leave empty to disable email monitoring
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_TLS=true
EMAIL_CACHE_TTL_SECONDS=300

# ─── Logs ────────────────────────────────────────────────────────────────────
# Format: name:type:path (comma-separated). Types: file, journald, docker
LOG_SOURCES=syslog:file:/var/log/syslog,nginx:file:/var/log/nginx/access.log
LOG_INDEX_INTERVAL_SECONDS=300
LOG_TAIL_DEFAULT_LINES=100

# ─── Services Monitoring ────────────────────────────────────────────────────
# Comma-separated systemd service names to monitor
MONITORED_SERVICES=docker,nginx,sshd,fail2ban,postgresql,redis,cron,ufw

# ─── Hooks / Webhooks ───────────────────────────────────────────────────────
# HMAC-SHA256 secret for webhook verification (leave empty to disable)
WEBHOOK_SECRET=
# Event retention in days (default: 30)
HOOK_EVENT_TTL_DAYS=30

# ─── Notifications ──────────────────────────────────────────────────────────
# Telegram (optional)
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
# Discord (optional)
NOTIFY_DISCORD_WEBHOOK_URL=

# ─── Ansible (Phase 4) ─────────────────────────────────────────────────────
# Directory containing Ansible playbook YAML files
ANSIBLE_PLAYBOOK_DIR=/etc/ansible/playbooks
# Path to Ansible inventory file
ANSIBLE_INVENTORY=/etc/ansible/hosts

# ─── Secrets Vault / Bitwarden (Phase 4) ────────────────────────────────────
# Path to Bitwarden CLI binary
BW_CLI_PATH=bw
# Bitwarden session token (from `bw unlock`)
BW_SESSION=
