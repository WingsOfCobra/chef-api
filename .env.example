CHEF_API_KEY=your-secret-api-key-here
GITHUB_TOKEN=ghp_your_token_here
PORT=4242
HOST=0.0.0.0
DOCKER_SOCKET=/var/run/docker.sock
SSH_HOSTS=hostname1:user@host1:~/.ssh/keyname,hostname2:user@host2:~/.ssh/keyname
TODO_PATH=/path/to/your/TODO.md

# Cron: timezone for scheduled jobs (default: UTC)
CRON_TIMEZONE=UTC

# Hooks: HMAC-SHA256 secret for webhook verification (leave empty to disable)
WEBHOOK_SECRET=
# Hooks: Telegram notification (optional)
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
# Hooks: Discord notification (optional)
NOTIFY_DISCORD_WEBHOOK_URL=
# Hooks: event retention in days (default: 30)
HOOK_EVENT_TTL_DAYS=30

# Logs: sources to aggregate (format: name:type:path, comma-separated)
# Types: file, journald, docker
LOG_SOURCES=syslog:file:/var/log/syslog,nginx:file:/var/log/nginx/access.log
LOG_INDEX_INTERVAL_SECONDS=300
LOG_TAIL_DEFAULT_LINES=100

# Email: IMAP configuration (optional — leave empty to disable email monitoring)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_TLS=true
EMAIL_CACHE_TTL_SECONDS=300

# Docker Compose: which interface to bind on (e.g. 127.0.0.1 or a VPN IP)
BIND_ADDR=127.0.0.1
# Docker Compose: host path to mount as /workspace inside the container (read-only)
WORKSPACE_PATH=/path/to/your/workspace
